      "connection" : {
        "type" : "object",
        "properties" : {
          "serial_number" : {
            "type" : "number"
          },
          "connection_state" : {
            "type" : "string",
            "example" : "Alimenté"
          },
          "voltage_level" : {
            "type" : "string",
            "example" : "HTA"
          },
          "phase_count" : {
            "type" : "string"
          },
          "consumption_connection_power" : {
            "type" : "object",
            "properties" : {
              "value" : {
                "type" : "number"
              },
              "unit" : {
                "type" : "string"
              }
            }
          },
          "generation_connection_power" : {
            "type" : "object",
            "properties" : {
              "value" : {
                "type" : "number"
              },
              "unit" : {
                "type" : "string"
              }
            }
          },
          "nominal_service_voltage" : {
            "type" : "object",
            "properties" : {
              "value" : {
                "type" : "number"
              },
              "unit" : {
                "type" : "string"
              }
            }
          }
        }
      },
      "error" : {
        "required" : [ "code", "libelle" ],
        "type" : "object",
        "properties" : {
          "code" : {
            "type" : "string"
          },
          "libelle" : {
            "type" : "string"
          }
        }
      }
    },
    "securitySchemes" : {
      "default" : {
        "type" : "oauth2",
        "flows" : {
          "implicit" : {
            "authorizationUrl" : "https://gw.ext.prod.api.enedis.fr:443/authorize",
