{
  "openapi" : "3.0.1",
  "info" : {
    "title" : "Simulation de raccordement",
    "description" : "Cette API permet de simuler le niveau de complexité d’un raccordement au réseau d'ENEDIS",
    "termsOfService" : "urn:tos",
    "contact" : { },
    "license" : {
      "name" : "Apache 2.0",
      "url" : "http://www.apache.org/licenses/LICENSE-2.0"
    },
    "version" : "v4"
  },
  "servers" : [ {
    "url" : "https://gw.ext.prod.api.enedis.fr:443/grid_connection_simulation/v4"
  } ],
  "security" : [ {
    "default" : [ ]
  } ],
  "tags" : [ {
    "name" : "LV"
  }, {
    "name" : "MV"
  } ],
  "paths" : {
    "/LV" : {
      "post" : {
        "tags" : [ "LV" ],
        "summary" : "Demande de simulation d'un raccordement monopoint en BT",
        "description" : "Donne la complexité ainsi qu’éventuellement le coût d'un raccordement BT monopoint dont l'identifiant de demande est passé en paramètre",
        "parameters" : [ {
          "name" : "Content-Type",
          "in" : "header",
          "description" : "Format du body de la requête",
          "schema" : {
            "type" : "string"
          },
          "example" : "application/json;charset=UTF-8"
        }, {
          "name" : "Accept",
          "in" : "header",
          "description" : "Format de réponse acceptable",
          "schema" : {
            "type" : "string"
          },
          "example" : "application/json"
        }, {
          "name" : "Authorization",
          "in" : "header",
          "description" : "Token Oauth délivré à l’application cliente lors de la phase préalable d'autorisation. \nFormat : Bearer &lt;Valeur du token&gt;.",
          "required" : true,
          "schema" : {
            "type" : "string"
          },
          "example" : "5b5f2bee-1808-3f7e-bdfa-9415ea3708b8"
        }, {
          "name" : "User-Agent",
          "in" : "header",
          "description" : "Description de l'équipement qui a émis la requêtes (hardware/software)",
          "schema" : {
            "type" : "string"
          },
          "example" : "Mozilla/5.0 (Linux; U; Android 4.0.3; fr-fr; LG-L160L Build/IML74K)"
        }, {
          "name" : "Host",
          "in" : "header",
          "description" : "Nom de domaine du serveur et numéro de port TCP si différent du port 80.\nFormat : &lt;Nom de domaine&gt;:&lt;port TCP&gt;",
          "schema" : {
            "type" : "string"
          },
          "example" : "ext.hml.api.enedis.fr"
        } ],
        "requestBody" : {
          "content" : {
            "*/*" : {
              "schema" : {
                "required" : [ "installation_gps_location", "serviced_plot", "usage" ],
                "type" : "object",
                "properties" : {
                  "installation_gps_location" : {
                    "required" : [ "latitude", "longitude" ],
                    "type" : "object",
                    "properties" : {
                      "latitude" : {
                        "type" : "number",
                        "description" : "the angular distance to the equator (90 being north pole, -90 being south pole)",
                        "example" : 44.069055
                      },
                      "longitude" : {
                        "type" : "number",
                        "description" : "the angular distance to Greenwich meridian (0 being Greenwich, 180/-180 being near Waiyevo)",
                        "example" : 4.142446
                      }
                    }
                  },
                  "usage" : {
                    "type" : "string",
                    "description" : "The types of usage",
                    "example" : "ProductionOverConsumption",
                    "enum" : [ "Consumption", "Production ", "ConsumptionAndProduction", "ProductionOverConsumption" ]
                  },
                  "serviced_plot" : {
                    "type" : "boolean",
                    "description" : "True means there are facilities on the landspot that make installation easier.",
                    "example" : false
                  },
                  "adapt_power" : {
                    "type" : "boolean",
                    "description" : "True if TeR@ has to adapt power to remove constraints",
                    "example" : false
                  },
                  "injected_power" : {
                    "type" : "number",
                    "description" : "The power that is injected (produced) by the producer in kVA or kW",
                    "format" : "double",
                    "example" : 16.0
                  },
                  "subscribed_power" : {
                    "type" : "number",
                    "description" : "The power that is extracted (consumed) by the client in kVA or kW",
                    "format" : "double",
                    "example" : 16.0
                  },
                  "installed_phase" : {
                    "type" : "string",
                    "description" : "The nature of the cable already installed. AN for monophasic, ABCN for triphasic",
                    "example" : "AN",
                    "enum" : [ "AN", "ABCN" ]
                  },
                  "sales_strategy" : {
                    "type" : "string",
                    "description" : "THow the produced current will be sold to Enedis. Surplus being 'we want to sell what we do not consume localy'. Totality being 'we sell everything and rebuy what we consume'.",
                    "example" : "Surplus",
                    "enum" : [ "Surplus", "Totality" ]
                  }
                }
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "201" : {
            "description" : "La demande a bien été traitée, mais le calcul est encore en cours. L'estimation de temps restant est mise à jour.",
            "headers" : {
              "X-CreationTime" : {
                "description" : "Horodate de création de la simulation. Format HTTP-date (cf. RFC 7231)",
                "schema" : {
                  "type" : "string"
                }
              },
              "X-RemainingTimeHigh" : {
                "description" : "Estimation haute de la durée du traitement : nombre de secondes que l'on peut par exemple afficher à l'utilisateur final",
                "schema" : {
                  "type" : "number"
                }
              },
              "Location" : {
                "description" : "Identifiant du numéro de demande générée par le SI au format : Location: https://{API endpoint}/tera_externe/1.4/simulation/{request_id}",
                "schema" : {
                  "type" : "string"
                }
              },
              "X-RemainingTimeLow" : {
                "description" : "Estimation basse de la durée du traitement : nombre de secondes minimal à attendre avant la prochaine tentative de récupération de la réponse",
                "schema" : {
                  "type" : "number"
                }
              }
            },
            "content" : { }
          },
          "400" : {
            "description" : "Mauvais format",
            "content" : {
              "*/*" : {
                "schema" : {
                  "title" : "WrongFormatException",
                  "required" : [ "error", "error_description" ],
                  "type" : "object",
                  "properties" : {
                    "error" : {
                      "type" : "string",
                      "description" : "Le code identifiant l'erreur",
                      "example" : "bad_request",
                      "enum" : [ "bad_request" ]
                    },
                    "error_description" : {
                      "type" : "string",
                      "description" : "Le message expliquant l'erreur",
                      "example" : "Lattitude must be in range [-90.000000 , 90.000000]"
                    }
                  }
                }
              }
            }
          },
          "500" : {
            "description" : "Erreur Serveur",
            "content" : {
              "*/*" : {
                "schema" : {
                  "type" : "object",
                  "properties" : {
                    "error" : {
                      "type" : "string",
                      "description" : "Code de l’erreur retourné par le système.",
                      "example" : "technical_error"
                    },
                    "error_description" : {
                      "type" : "string",
                      "description" : "Description de l’erreur correspondant au code.",
                      "example" : "technical error, please try again later"
                    }
                  }
                }
              }
            }
          }
        },
        "security" : [ {
          "default" : [ ]
        } ],
        "x-auth-type" : "Application & Application User",
        "x-throttling-tier" : "Unlimited",
        "x-codegen-request-body-name" : "body"
      }
    },
