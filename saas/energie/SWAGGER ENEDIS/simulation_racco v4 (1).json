                          "example" : "Estimated",
                          "enum" : [ "Estimated", "QuoteNeeded" ]
                        },
                        "fixed_part" : {
                          "type" : "number",
                          "description" : "How much the connection works will cost to the customer, without the linear part",
                          "example" : 2705.76
                        },
                        "linear_part" : {
                          "type" : "number",
                          "description" : "How much the connection works will cost to the customer, linear part. May equals 0.",
                          "example" : 138.19
                        }
                      },
