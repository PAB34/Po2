{
  "name": "PatrimoineOp",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace/saas",
  "shutdownAction": "stopCompose",
  "forwardPorts": [5173, 8000, 5432],
  "portsAttributes": {
    "5173": {
      "label": "Frontend Vite",
      "onAutoForward": "notify"
    },
    "8000": {
      "label": "Backend FastAPI",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "postCreateCommand": "python -m pip install --upgrade pip && pip install -r backend/requirements.txt && npm install --prefix frontend"
}
